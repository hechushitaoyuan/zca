# ── 服务 ──────────────────────────────────────────
ZCODE_PORT=3000
ZCODE_HOST=0.0.0.0

# 宿主机监听地址（compose.yaml 端口绑定使用）
#   127.0.0.1 = 仅本机可访问（默认，安全；配合 Cloudflare Tunnel / SSH 转发）
#   0.0.0.0   = 监听所有网卡 = 公网可直连
# ⚠️ 设为 0.0.0.0 前，必须先设置非空强 ZCODE_ADMIN_KEY 与 ZCODE_GATEWAY_KEY，
#    并确认云防火墙仅放行预期来源（详见 docs/DEPLOYMENT.md）。
ZCA_BIND_IP=127.0.0.1

# ── 部署镜像（compose.yaml 使用，不在 VPS 上 build）──
# 替换为你的 Docker Hub 用户名；可用 :latest 或固定为某个 :sha-xxxxxxx 以便回滚
ZCA_IMAGE=your-dockerhub-user/zca:latest

# ── 鉴权 ──────────────────────────────────────────
# 后台管理密码（首次启动写入 data/accounts.db，之后以数据库为准）
# ⚠️ 生产部署前必须改成强密码，切勿沿用默认值 zcode
ZCODE_ADMIN_KEY=zcode

# 网关 API Key（调用 /v1/messages 的鉴权）。默认空 = 仅适合回环本机使用。
#   - 新库：用此值初始化数据库 gateway_key
#   - 既有库：仅当数据库内当前为空时用此值补齐；绝不覆盖你已在后台设置的非空值
# ⚠️ 公网监听（ZCA_BIND_IP=0.0.0.0）前必须设为强随机非空值。留空则不改动数据库现状。
ZCODE_GATEWAY_KEY=

# ── 数据目录（账号保存在本目录下的 SQLite）────────
# 容器部署：必须为 /data，与 compose.yaml 的 ./data:/data 挂载卷一致，
# 否则 env_file 会覆盖镜像默认值，SQLite 写入 /app/data 绕过挂载卷、重建容器丢账号。
ZCODE_DATA_DIR=/data

# ── 用量监控 ──────────────────────────────────────
# 后台自动刷新各账号额度的间隔（秒），0 关闭
ZCODE_QUOTA_REFRESH_INTERVAL=60
# 限流冷却时长（秒）
ZCODE_COOLING_SECONDS=300
# 3012 风控按连续失败次数指数退避（秒）
ZCODE_3012_COOLDOWN_BASE=300
ZCODE_3012_COOLDOWN_MAX=7200
# 单账号同时转发的最大请求数
ZCODE_ACCOUNT_CONCURRENCY_LIMIT=1

# ── 无痕验证求解（无浏览器：Node + jsdom）──────────
# Node 可执行文件（默认走 PATH 中的 node）
# ZCODE_NODE_PATH=node
# 单次求解超时（秒）与失败重试次数
# ZCODE_CAPTCHA_TIMEOUT=40
# ZCODE_CAPTCHA_RETRIES=4

# ── 验证码缓存 ────────────────────────────────────
# CAPTCHA_CACHE_TTL=45000
# CAPTCHA_CONFIG_CACHE_TTL=600000

# ── ZCode 客户端身份（一般无需修改）────────────────
# ZCODE_CLIENT_VERSION=3.1.2
# ZCODE_SOURCE_TITLE=cli
# ZCODE_REFERER=https://zcode.z.ai

# ── 上游端点（一般无需修改）───────────────────────
# ZAI_UPSTREAM_URL=https://zcode.z.ai/api/v1/zcode-plan/anthropic/v1/messages
# ZAI_FALLBACK_URL=https://api.z.ai/api/anthropic/v1/messages
# BIGMODEL_UPSTREAM_URL=https://open.bigmodel.cn/api/anthropic/v1/messages
# UPSTREAM_USER_AGENT=ZCode/3.1.2
